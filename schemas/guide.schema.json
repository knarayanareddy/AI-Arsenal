{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/guide.schema.json",
  "title": "AI Arsenal Guide Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "title", "entry_type", "section", "description", "tags", "added_date", "last_reviewed", "added_by", "status"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "entry_type": { "const": "guide" },
    "section": { "enum": ["trending", "tools", "observability", "research", "architectures", "skills", "community", "benchmarks"] },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "related_entries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "default": [] },
    "added_date": { "$ref": "#/$defs/date" },
    "last_reviewed": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "status": { "enum": ["active", "archived", "deprecated", "watching"] }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

