{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/trend.schema.json",
  "title": "AI Arsenal Trend Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": [
    "id",
    "title",
    "entry_type",
    "kind",
    "status",
    "as_of",
    "signals_used",
    "sources",
    "last_reviewed",
    "added_date",
    "added_by"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "entry_type": { "const": "trend" },
    "kind": {
      "enum": ["weekly-snapshot", "hall-of-fame", "source-feed"]
    },
    "status": {
      "enum": ["draft", "reviewed", "published", "deprecated"]
    },
    "as_of": { "$ref": "#/$defs/date" },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "$ref": "#/$defs/date" },
        "end": { "$ref": "#/$defs/date" }
      }
    },
    "signals_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "github-stars-velocity",
          "github-stars-total",
          "github-activity",
          "newsletter-feature",
          "release",
          "paper-attention",
          "community-buzz",
          "breaking-change",
          "security-issue"
        ]
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "url", "last_checked"],
        "properties": {
          "source": {
            "enum": [
              "github",
              "toolradar-techpresso",
              "arxiv",
              "papers-with-code",
              "hackernews",
              "reddit",
              "x",
              "blog",
              "other"
            ]
          },
          "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
          "last_checked": { "$ref": "#/$defs/date" },
          "notes": { "type": "string" }
        }
      }
    },
    "ranked_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "entry_id", "entry_type", "why_here"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "entry_id": { "type": "string", "minLength": 1 },
          "entry_type": { "type": "string", "minLength": 1 },
          "why_here": { "type": "string", "minLength": 1 },
          "score_snapshot": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "last_reviewed": { "$ref": "#/$defs/date" },
    "added_date": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "notable_changes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "watchlist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "enrichment_status": {
      "enum": ["draft", "reviewed", "verified"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "weekly-snapshot" } } },
      "then": {
        "required": ["window"],
        "properties": {
          "ranked_entries": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "hall-of-fame" } } },
      "then": {
        "properties": {
          "ranked_entries": { "type": "array", "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "githubUser": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
    }
  }
}
