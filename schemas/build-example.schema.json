{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/build-example.schema.json",
  "title": "AI Arsenal Build Example Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "2.0.0",
  "x-migration-note": "Build-examples-vertical reorganisation COMPLETE (8/8 build examples migrated into 7 phase folders, confirmed via `pnpm run migration:build-examples:progress` reporting 100%). This atomic commit flips the previously-optional-but-typed migration fields to required, matching the exact sequencing used for the tools/projects/research/tips verticals. `stack` was originally planned (see the Architect's Step 1.5 note) to get `minItems: 2` post-migration, on the assumption that every build uses at least two catalog-tracked components -- but the pre-flight scan found 2 of 8 entries (starter-local-llm-chat, starter-simple-react-agent) genuinely and correctly have only ONE stack value that resolves to a real catalog ID (Docker and Open WebUI have no catalog entries; the OpenAI API itself is not tracked as a catalog project, only openai-agents-sdk/openai-evals are). Rather than force a fabricated second dependency to satisfy an arbitrary minItems, `stack` is set to `minItems: 1` here, matching ground truth. All 8 entries' `stack` values were independently verified to resolve to real content/projects or content/tools IDs (no free-text stack/language tags remain, unlike the pre-migration state).",
  "required": ["id", "title", "difficulty", "description", "tags", "stack", "estimated_time", "repo_url", "added_date", "added_by", "status", "phase", "build_status", "outcome", "prerequisites", "last_reviewed", "enrichment_status"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 140 },
    "difficulty": { "enum": ["starter", "intermediate", "advanced"] },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "stack": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "estimated_time": { "type": "string", "minLength": 1, "maxLength": 80 },
    "repo_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "demo_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "added_date": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "last_reviewed": { "$ref": "#/$defs/date" },
    "status": { "enum": ["active", "archived", "deprecated", "watching"] },

    "phase": {
      "enum": ["rag-systems", "agent-systems", "fine-tuning-workflows", "evaluation-pipelines", "production-deployment", "multimodal", "data-pipelines"]
    },
    "build_status": { "enum": ["tested", "untested", "outdated", "community-built"] },
    "outcome": { "enum": ["working-prototype", "production-ready", "learning-reference"] },
    "cost_estimate": { "type": "string", "minLength": 1, "maxLength": 80 },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tested_on": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "python_version", "key_package_versions"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "python_version": { "type": "string", "minLength": 1 },
        "key_package_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extends": { "$ref": "#/$defs/kebabId" },
    "extended_by": {
      "type": "array",
      "items": { "$ref": "#/$defs/kebabId" },
      "uniqueItems": true
    },
    "implements_pattern": { "$ref": "#/$defs/kebabId" },
    "related_tips": {
      "type": "array",
      "items": { "$ref": "#/$defs/kebabId" },
      "uniqueItems": true
    },
    "enrichment_status": { "enum": ["draft", "reviewed", "verified"] },
    "enrichment_notes": { "type": "string", "maxLength": 600 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "build_status": { "const": "tested" } },
        "required": ["build_status"]
      },
      "then": {
        "required": ["tested_on"]
      }
    }
  ],
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}
