{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/tool.schema.json",
  "title": "AI Arsenal Tool Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "name", "type", "job", "description", "url", "cost_model", "pricing_detail", "tags", "maturity", "stack", "free_tier", "self_hostable", "open_source", "added_date", "last_reviewed", "added_by", "verdict", "verdict_rationale", "status"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "type": { "const": "tool" },
    "job": { "type": "array", "minItems": 1, "items": { "enum": ["prototyping", "production-serving", "fine-tuning", "evaluation", "deployment", "orchestration", "vector-search", "memory-management", "web-scraping", "structured-output", "prompt-management", "data-labeling", "model-registry", "security-and-guardrails", "tracing", "monitoring"] }, "uniqueItems": true },
    "description": { "type": "string", "minLength": 10, "maxLength": 160 },
    "url": { "$ref": "#/$defs/url" },
    "cost_model": { "enum": ["open-source", "freemium", "paid", "self-hostable", "usage-based"] },
    "pricing_detail": { "type": "string", "minLength": 1, "maxLength": 240 },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "maturity": { "enum": ["experimental", "alpha", "beta", "production"] },
    "stack": { "type": "array", "minItems": 1, "items": { "enum": ["python", "typescript", "rust", "go", "java", "cpp", "julia", "polyglot"] }, "uniqueItems": true },
    "free_tier": { "type": "boolean" },
    "free_tier_limits": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "self_hostable": { "type": "boolean" },
    "open_source": { "type": "boolean" },
    "source_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "docs_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "github_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "alternatives": { "$ref": "#/$defs/stringArray" },
    "integrates_with": { "$ref": "#/$defs/stringArray" },
    "added_date": { "$ref": "#/$defs/date" },
    "last_reviewed": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "reviewed_by": { "anyOf": [{ "$ref": "#/$defs/githubUser" }, { "type": "null" }] },
    "verdict": { "enum": ["best-in-class", "recommended", "solid-choice", "use-with-caution", "deprecated", "watching"] },
    "verdict_rationale": { "type": "string", "minLength": 1, "maxLength": 200 },
    "status": { "enum": ["active", "archived", "deprecated", "watching"] }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "stringArray": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "default": [] },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

