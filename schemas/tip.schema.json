{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/tip.schema.json",
  "title": "AI Arsenal Tip Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "title", "category", "tags", "difficulty", "impact", "time_to_implement", "applies_to", "added_date", "added_by"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 140 },
    "category": { "enum": ["prompting", "inference-optimization", "rag-tuning", "cost-reduction", "debugging-llm-apps", "latency-optimization", "context-window-management", "agent-reliability", "production-gotchas", "local-model-tips", "security-best-practices"] },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
    "impact": { "enum": ["low", "medium", "high"] },
    "time_to_implement": { "type": "string", "minLength": 1, "maxLength": 80 },
    "applies_to": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "added_date": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "verified_by": { "anyOf": [{ "$ref": "#/$defs/githubUser" }, { "type": "null" }] },
    "source_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

