{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/community.schema.json",
  "title": "AI Arsenal Community Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "x-migration-note": "Community-vertical reorganisation. This is a NEW dedicated schema, not bolted onto guide.schema.json, per the brief's explicit instruction. Fields below are required from schema v1.0.0 with no partial-migration window -- all pre-existing content/community/*.md directory-style guide entries (discord-communities.md, newsletters.md, podcasts.md, youtube-channels.md, people-to-follow.md) were retired (deleted, not migrated) in the same pass that introduces this schema, since they mixed entity kinds and carried no activity evidence or safety notes (see .migration/community-audit-report.md). Deliberate deviation from every other vertical's schema: this schema does NOT require added_date/added_by/status, because the reorganisation brief's own canonical frontmatter template (Phase 3) omits them in favor of last_checked/last_reviewed as the load-bearing dates for a vertical whose entire premise is time-sensitive activity evidence, not catalog provenance. The content/community/people/ person entries are untouched by this migration and continue to validate against person.schema.json.",
  "required": [
    "id",
    "title",
    "entry_type",
    "kind",
    "url",
    "topics",
    "audience",
    "access",
    "activity_level",
    "activity_evidence",
    "last_checked",
    "safety_level",
    "how_to_get_value",
    "what_to_avoid",
    "last_reviewed"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "safety_level": { "not": { "const": "generally-safe" } } },
        "required": ["safety_level"]
      },
      "then": {
        "required": ["safety_notes"],
        "properties": {
          "safety_notes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  ],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "entry_type": { "const": "community" },
    "kind": { "enum": ["forum", "chat", "newsletter", "event", "meetup", "creator", "dataset"] },
    "url": { "$ref": "#/$defs/url" },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["llm-engineering", "rag", "agents", "fine-tuning", "evals", "observability", "open-source", "safety", "multimodal", "infra", "research"] },
      "uniqueItems": true
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["beginner", "practitioner", "researcher", "founder", "enterprise"] },
      "uniqueItems": true
    },
    "access": { "enum": ["public", "invite-only", "paid"] },
    "activity_level": { "enum": ["very-active", "active", "intermittent", "quiet", "unknown"] },
    "activity_evidence": { "type": "string", "minLength": 10, "maxLength": 300 },
    "last_checked": { "$ref": "#/$defs/date" },
    "safety_level": { "enum": ["generally-safe", "caution", "avoid"] },
    "safety_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "how_to_get_value": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "what_to_avoid": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "last_reviewed": { "$ref": "#/$defs/date" },

    "owner_org": { "type": "string", "minLength": 1, "maxLength": 120 },
    "region": { "type": "string", "minLength": 1, "maxLength": 120 },
    "cost": { "type": "string", "minLength": 1, "maxLength": 60 },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "enrichment_status": { "enum": ["draft", "reviewed", "verified"] },
    "enrichment_notes": { "type": "string", "maxLength": 600 },

    "related_communities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_projects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_research": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}
