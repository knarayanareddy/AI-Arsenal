{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/digest.schema.json",
  "title": "AI Arsenal Monthly Digest Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "title", "period", "published_date", "summary", "highlights", "tags", "added_by"],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "published_date": { "$ref": "#/$defs/date" },
    "summary": { "type": "string", "minLength": 20, "maxLength": 500 },
    "highlights": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "top_projects": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "default": [] },
    "top_tools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "default": [] },
    "added_by": { "$ref": "#/$defs/githubUser" }
  },
  "$defs": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

