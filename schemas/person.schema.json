{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/person.schema.json",
  "title": "AI Arsenal Person Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "name", "role", "description", "url", "tags", "channels", "added_date", "added_by", "status"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "role": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "url": { "$ref": "#/$defs/url" },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "channels": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["type", "url"], "properties": { "type": { "enum": ["x-twitter", "youtube", "github", "newsletter", "podcast", "website", "linkedin"] }, "url": { "$ref": "#/$defs/url" } } } },
    "added_date": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "last_reviewed": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
    "status": { "enum": ["active", "archived", "deprecated", "watching"] }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

