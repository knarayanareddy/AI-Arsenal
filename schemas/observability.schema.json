{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/observability.schema.json",
  "title": "AI Arsenal Observability Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "x-migration-note": "Observability-vertical reorganisation. This is a NEW dedicated schema, not bolted onto guide.schema.json, per the brief's explicit instruction. Fields below are required from schema v1.0.0 -- there is no partial-migration window where old-shaped and new-shaped observability entries coexist under this schema, since all pre-existing content/observability/*.md entries were either retired (superseded by content/architectures/evaluation-strategy/choose-observability-tool.md, which already covers the same decision-tree ground) or rewritten from scratch into the new operational-playbook format in the same pass that introduces this schema. Entries not yet migrated remain entry_type: 'guide' and validate against guide.schema.json until individually migrated; see scripts/check-observability-migration-progress.js.",
  "required": [
    "id",
    "title",
    "entry_type",
    "category",
    "scope",
    "signal_types",
    "verification_status",
    "data_sensitivity",
    "instrumentation_contract",
    "last_reviewed",
    "added_date",
    "added_by",
    "status",
    "enrichment_status"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "entry_type": { "const": "observability" },
    "category": {
      "enum": ["instrumentation", "tracing", "evaluation-quality", "monitoring-alerting", "cost-usage", "privacy-governance", "incident-response"]
    },
    "scope": { "enum": ["prototype", "production"] },
    "signal_types": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["latency", "cost", "quality", "safety", "reliability", "throughput", "user-satisfaction"] },
      "uniqueItems": true
    },
    "verification_status": { "enum": ["production-verified", "lab-verified", "community-reported", "theoretical"] },
    "data_sensitivity": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["public", "internal", "pii", "secrets", "regulated"] },
      "uniqueItems": true
    },

    "instrumentation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events", "sampling", "retention", "correlation", "redaction"],
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "when_emitted", "required_fields", "pii_risk"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "when_emitted": { "type": "string", "minLength": 1 },
              "required_fields": {
                "type": "array",
                "minItems": 3,
                "items": { "type": "string", "minLength": 1 }
              },
              "optional_fields": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "pii_risk": { "enum": ["public", "internal", "pii", "secrets", "regulated"] }
            }
          }
        },
        "sampling": { "type": "string", "minLength": 1 },
        "retention": { "type": "string", "minLength": 1 },
        "correlation": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "redaction": { "type": "string", "minLength": 1 }
      }
    },

    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "added_date": { "$ref": "#/$defs/date" },
    "last_reviewed": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "status": { "enum": ["active", "archived", "deprecated", "watching"] },
    "enrichment_status": { "enum": ["draft", "reviewed", "verified"] },

    "related_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_projects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_build_examples": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "related_tips": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "dashboards": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "alert_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "common_failure_modes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "supersedes": { "$ref": "#/$defs/kebabId" },
    "superseded_by": { "$ref": "#/$defs/kebabId" }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}
