{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/research.schema.json",
  "title": "AI Arsenal Research Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "x-migration-note": "Research-vertical reorganisation: COMPLETE as of 2026-07-01 (25/25 entries migrated, confirmed via `pnpm run migration:research:progress` reporting 100%). This schema now applies to every research entry -- content/research/papers/ (the pre-migration flat location) has been removed entirely, and schemas/paper.schema.json is retired; scripts/validate-schema.js's dispatch logic (dispatch-by-`phase`-presence) is now a no-op since every entry carries `phase`, but is left in place rather than removed since it is harmless and documents the migration history. All previously-optional fields are now required, matching this schema's `x-required-after-migration` list from the migration period. CI now runs `migration:research:enforce` (exit 1 if any entry regresses below 100%) instead of `migration:research:progress`, in the same atomic commit as this required-fields flip, per the schema promotion sequencing rule established for the tools and projects verticals.",
  "required": ["id", "title", "authors", "tags", "added_date", "added_by", "phase", "venue", "year", "practical_applicability", "reproduction_status", "result_status", "has_code", "tldr", "key_contribution", "last_reviewed"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "phase": { "enum": ["foundational", "architectures", "training-and-alignment", "inference-and-efficiency", "retrieval-and-memory", "agents-and-reasoning", "evaluation-and-safety", "surveys"] },
    "venue": { "enum": ["neurips", "icml", "iclr", "acl", "emnlp", "arxiv-preprint", "blog-post", "technical-report", "other"] },
    "year": { "type": "integer", "minimum": 1990, "maximum": 2100 },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },

    "arxiv_id": { "type": "string", "pattern": "^(\\d{4}\\.\\d{4,5})(v\\d+)?$" },
    "arxiv_url": { "$ref": "#/$defs/url" },
    "pdf_url": { "$ref": "#/$defs/url" },
    "code_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "venue_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },

    "practical_applicability": { "enum": ["high", "medium", "low", "theoretical"] },
    "reproduction_status": { "enum": ["reproduced", "partially-reproduced", "not-reproduced", "code-available", "no-code"] },
    "result_status": { "enum": ["current", "superseded", "challenged", "foundational"] },
    "has_code": { "type": "boolean" },
    "citation_count_approx": { "type": "integer", "minimum": 0 },

    "tldr": { "type": "string", "minLength": 10, "maxLength": 280 },
    "key_contribution": { "type": "string", "minLength": 10, "maxLength": 400 },

    "superseded_by": { "anyOf": [{ "$ref": "#/$defs/kebabId" }, { "type": "null" }] },
    "builds_on": { "type": "array", "items": { "$ref": "#/$defs/kebabId" }, "default": [] },
    "implemented_in": { "type": "array", "items": { "$ref": "#/$defs/kebabId" }, "default": [] },
    "corresponding_project_entry": { "anyOf": [{ "$ref": "#/$defs/kebabId" }, { "type": "null" }] },

    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },

    "added_date": { "$ref": "#/$defs/date" },
    "last_reviewed": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
    "added_by": { "$ref": "#/$defs/githubUser" },
    "enrichment_status": { "enum": ["draft", "reviewed", "verified"] }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}
