{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-arsenal.local/schemas/paper.schema.json",
  "title": "AI Arsenal Research Paper Entry",
  "type": "object",
  "additionalProperties": false,
  "x-schema-version": "1.0.0",
  "required": ["id", "title", "authors", "published_date", "venue", "arxiv_id", "arxiv_url", "pdf_url", "tags", "category", "importance", "citation_count", "has_code", "tldr", "why_it_matters", "added_date", "added_by"],
  "properties": {
    "id": { "$ref": "#/$defs/kebabId" },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "published_date": { "$ref": "#/$defs/date" },
    "venue": { "type": "string", "minLength": 1, "maxLength": 120 },
    "arxiv_id": { "type": "string", "pattern": "^(\\d{4}\\.\\d{4,5})(v\\d+)?$" },
    "arxiv_url": { "$ref": "#/$defs/url" },
    "pdf_url": { "$ref": "#/$defs/url" },
    "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
    "category": { "enum": ["architecture", "training", "inference", "rag", "agents", "evaluation", "alignment", "multimodal", "efficiency"] },
    "importance": { "enum": ["foundational", "sota", "incremental", "benchmark", "survey"] },
    "citation_count": { "type": "integer", "minimum": 0 },
    "has_code": { "type": "boolean" },
    "code_url": { "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }] },
    "benchmark_improvements": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["benchmark", "score"], "properties": { "benchmark": { "type": "string", "minLength": 1 }, "score": { "type": "string", "minLength": 1 }, "previous_sota": { "type": ["string", "null"] } } }, "default": [] },
    "tldr": { "type": "string", "minLength": 10, "maxLength": 200 },
    "why_it_matters": { "type": "string", "minLength": 20, "maxLength": 1000 },
    "added_date": { "$ref": "#/$defs/date" },
    "added_by": { "$ref": "#/$defs/githubUser" }
  },
  "$defs": {
    "kebabId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "not": { "enum": ["index", "registry", "overview", "introduction", "readme", "agent", "context", "taxonomy", "contributing", "governance", "changelog", "security", "template", "all", "none", "undefined", "null", "true", "false"] } },
    "url": { "type": "string", "pattern": "^https?://[^\\s]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "githubUser": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}

