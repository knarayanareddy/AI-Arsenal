# GitHub star count cache (regenerated weekly; not source of truth and
# contains GitHub API responses for external repos which can be used
# for reconnaissance if leaked. Move to a secret-backed GH Cache in a
# future release).
data/github-cache.json

# Local lockfile for concurrent update:stars runs.
data/.star-lock

# Scratch input data used to drive the one-time tools-vertical-reorg
# migration scripts (scripts/migrate-tools-to-phases.js and friends). Its
# content is now fully reflected in the migrated content/tools/**/*.md
# frontmatter, which is the source of truth; kept out of git to avoid a
# duplicate, driftable copy of the same data.
.migration/


