node_modules/
.npm/
.cache/
.DS_Store
.env
.env.*
!.env.example
coverage/
dist/
build/
.data-release/

# Generated data (regenerated by automation; do not hand-edit).
data/*.json

# Generated registries and index files (regenerated by `pnpm run generate:toc`).
content/**/_registry.md
content/**/_index.md

# GitHub star count cache (regenerated weekly; not source of truth and
# contains GitHub API responses for external repos which can be used
# for reconnaissance if leaked. Move to a secret-backed GH Cache in a
# future release).
data/github-cache.json

# Local lockfile for concurrent update:stars runs.
data/.star-lock

# Editor / OS scratch files
*.swp
*.swo
*~
