# EditorConfig is awesome: https://EditorConfig.org
# Keeps the repo consistent across editors and operating systems.
# The fix-format script normalizes these properties on commit.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false  # Markdown uses two trailing spaces for line breaks.

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
